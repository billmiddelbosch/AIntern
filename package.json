{
  "name": "aintern",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite-ssg build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write src/",
    "type-check": "vue-tsc --noEmit",
    "sync:backlog": "aws s3 cp product/backlog.md s3://aintern-kennisbank/admin-assets/backlog.md",
    "sitemap:generate": "npx tsx scripts/generate-sitemap.ts",
    "question": "test.ts"
  },
  "dependencies": {
    "@unhead/vue": "^2.1.12",
    "@vueuse/core": "^12.4.0",
    "axios": "^1.7.9",
    "dompurify": "^3.4.0",
    "pinia": "^2.3.1",
    "tesseract.js": "^7.0.0",
    "vite-ssg": "^28.3.0",
    "vue": "^3.5.13",
    "vue-i18n": "^11.1.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1031.0",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-vue": "^10.0.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.11",
    "vite-ssg-sitemap": "^0.10.0",
    "vitest": "^3.0.4",
    "vue-eslint-parser": "^10.0.0",
    "vue-tsc": "^2.2.0"
  },
  "overrides": {
    "@unhead/dom": ">=2.1.13"
  }
}
